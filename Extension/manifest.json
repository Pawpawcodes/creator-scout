{
  "manifest_version": 3,
  "key": "",
  "name": "Creator Scout",
  "version": "1.0.0",
  "description": "Scout and save creator profiles from LinkedIn, Twitter, and Instagram",
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://twitter.com/*",
    "https://x.com/*",
    "https://www.instagram.com/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Creator Scout",
    "default_icon": "icon.svg"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["content.js"]
    }
  ]
}
