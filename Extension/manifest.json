{
  "manifest_version": 3,
  "name": "Creator Scout",
  "version": "1.0.0",
  "description": "Scout and track creators across LinkedIn, Twitter/X, and Instagram",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.instagram.com/*",
    "https://script.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/in/*",
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Creator Scout"
  }
}
